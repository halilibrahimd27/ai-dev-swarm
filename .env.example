# ai-dev-swarm — environment variables
#
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
# All values are read through `src/aidevswarm/settings.py` (pydantic-settings).

# --- LLM ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
AIDEVSWARM_MODEL_STRONG=claude-opus-4-7
AIDEVSWARM_MODEL_FAST=claude-haiku-4-5

# --- GitHub publishing (used by the github_tool in pr_only mode) ----------
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username
AIDEVSWARM_GITHUB_MODE=pr_only          # pr_only | auto_merge

# --- Telegram (one-way notifications in Phase 0) --------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Postgres + pgvector --------------------------------------------------
POSTGRES_USER=aidevswarm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aidevswarm
# Used by the orchestrator container; localhost when running outside compose.
AIDEVSWARM_PG_HOST=postgres
AIDEVSWARM_PG_PORT=5432

# --- Redis (kill switch) --------------------------------------------------
AIDEVSWARM_REDIS_HOST=redis
AIDEVSWARM_REDIS_PORT=6379

# --- Budgets / scheduling -------------------------------------------------
AIDEVSWARM_DAILY_TOKEN_BUDGET=2000000
AIDEVSWARM_PER_MILESTONE_TOKEN_BUDGET=400000
AIDEVSWARM_BUILD_CONCURRENCY=1
AIDEVSWARM_MILESTONE_RETRY_LIMIT=3
AIDEVSWARM_REQUIRE_APPROVAL=true
AIDEVSWARM_TICK_SECONDS=30

# --- Workspace ------------------------------------------------------------
AIDEVSWARM_WORKSPACES_DIR=/workspace/workspaces
