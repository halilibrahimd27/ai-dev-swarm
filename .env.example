# ai-dev-swarm — environment variables
#
# 1) Copy this file:                cp .env.example .env
# 2) Fill the REQUIRED block.       The system refuses to start
#                                   without these.
# 3) Fill the RECOMMENDED block     for GitHub publishing + Telegram
#    if you want them.              control. Both work without keys
#                                   (notifications degrade to logs).
# 4) Leave OPTIONAL knobs alone     unless you know why you're
#                                   changing them.
#
# All values are read through `src/aidevswarm/settings.py`. `.env`
# is gitignored — never commit it.

# ════════════════════════════════════════════════════════════════════
# REQUIRED — the system won't start without these
# ════════════════════════════════════════════════════════════════════

# Your Anthropic API key. Get one at https://console.anthropic.com
# (Settings → API Keys → Create Key). Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-...

# Postgres password. Used by docker-compose to initialise the DB on
# first boot AND by the orchestrator to connect. Any non-empty string.
POSTGRES_PASSWORD=change-me

# ════════════════════════════════════════════════════════════════════
# RECOMMENDED — wire these to get the full experience
# ════════════════════════════════════════════════════════════════════

# GitHub personal access token. Used by the publisher to open PRs
# against your repos. Get one at github.com/settings/tokens →
# Generate new token (classic). Scopes: `public_repo` (or `repo`
# if you want private repos), `read:user`.
GITHUB_TOKEN=ghp_...
# Your GitHub username (the owner of the repos ai-dev-swarm publishes
# to). Required only if GITHUB_TOKEN is set.
GITHUB_OWNER=your-github-username

# Git author identity stamped on EVERY commit in the generated projects'
# repos (and the bootstrap commit). Leave blank to fall back to
# GITHUB_OWNER as the name and `<owner>@users.noreply.github.com` as the
# email. For GitHub to attribute the commits to YOUR account, set
# AIDEVSWARM_GIT_AUTHOR_EMAIL to a *verified* email on your account, or
# your private `<id>+<username>@users.noreply.github.com` form (copy it
# from github.com/settings/emails). The "Co-Authored-By: Claude" trailer
# is disabled automatically — commits carry your identity only.
AIDEVSWARM_GIT_AUTHOR_NAME=
AIDEVSWARM_GIT_AUTHOR_EMAIL=


# Telegram bot token. Create a bot via @BotFather on Telegram
# (/newbot) and paste the token it gives you (looks like
# 123456:ABC-DEF...). The bot polls — no public webhook needed.
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID. Send /start to your new bot, then visit
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates and copy
# `result[0].message.chat.id`. The orchestrator sends one-way alerts
# (project shipped, milestone blocked) to this chat.
TELEGRAM_CHAT_ID=
# Comma-separated allow-list of Telegram user IDs that can issue
# COMMANDS (approve, abort, kill, etc.). The bidirectional control
# bot SILENTLY DENIES everyone else. Empty = no one can command.
# Find your numeric user ID by chatting with @userinfobot.
AIDEVSWARM_TELEGRAM_ALLOWED_USER_IDS=

# ════════════════════════════════════════════════════════════════════
# LLM model tiers — sensible defaults
# ════════════════════════════════════════════════════════════════════

# Strong model: powers planning, ideation, replanner, build/review.
# IMPORTANT: keep the `anthropic/` prefix so LiteLLM routes through the
# Anthropic Messages API instead of falling through to OpenAI.
AIDEVSWARM_MODEL_STRONG=anthropic/claude-opus-4-7
# Fast model: used by the Scout + Tester + Diagnostician roles.
AIDEVSWARM_MODEL_FAST=anthropic/claude-haiku-4-5
# Developer (build) model. Building is ~83% of spend, so the Developer
# uses this cheaper model for a first attempt and only ESCALATES to
# MODEL_STRONG (Opus) when a milestone fails and is retried. Keep the
# `anthropic/` prefix.
AIDEVSWARM_MODEL_DEV=anthropic/claude-sonnet-4-6
# Max output tokens for the JSON-emitting crews (planning, ideation,
# replanner, reviewer). Too low and a milestone-graph JSON truncates
# and fails to parse, blocking the project. 16k fits comfortably.
AIDEVSWARM_MAX_OUTPUT_TOKENS=16000
# Haiku model the Telegram bot uses to parse free-form text into
# typed commands. Cheap (~$0.0001 per message).
AIDEVSWARM_HAIKU_MODEL=anthropic/claude-haiku-4-5

# ════════════════════════════════════════════════════════════════════
# Postgres / Redis host bindings
# ════════════════════════════════════════════════════════════════════

POSTGRES_USER=aidevswarm
POSTGRES_DB=aidevswarm

# Hostname the orchestrator uses to reach Postgres. Inside docker
# compose it's the service name `postgres`. For `python -m aidevswarm`
# on bare metal, set to `localhost`.
AIDEVSWARM_PG_HOST=postgres
AIDEVSWARM_PG_PORT=5432

# psycopg_pool tuning (rarely needs changing).
AIDEVSWARM_PG_POOL_MIN=4
AIDEVSWARM_PG_POOL_MAX=20
AIDEVSWARM_PG_POOL_TIMEOUT=10
AIDEVSWARM_PG_POOL_MAX_LIFETIME=1800

# Host-side ports the compose stack publishes. Bump if your host
# already uses 5432/6379. `docker compose up` reads these.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Redis (the kill switch + per-project kill keys live here).
AIDEVSWARM_REDIS_HOST=redis
AIDEVSWARM_REDIS_PORT=6379

# ════════════════════════════════════════════════════════════════════
# Control plane (Phase 5) — FastAPI + web UI
# ════════════════════════════════════════════════════════════════════

# Inside `docker compose`: leave as 0.0.0.0 (the container binds the
# bridge interface; docker publishes only to host loopback).
# Bare-metal: set to 127.0.0.1 so the API is loopback-only on the
# host. LAN IPs are REFUSED at startup.
AIDEVSWARM_API_HOST=127.0.0.1
AIDEVSWARM_API_PORT=8080
# Optional shared bearer token for the control plane. When set, every
# state-changing request (POST /api/commands) must carry
# `Authorization: Bearer <token>`; the web UI gets it injected automatically.
# Leave blank to rely on the loopback bind + Origin guard alone. A malicious
# local web page can't forge a cross-origin POST regardless (Origin guard),
# but a token also blocks any other local process. Generate one with e.g.
# `openssl rand -hex 32`.
AIDEVSWARM_API_TOKEN=

# ════════════════════════════════════════════════════════════════════
# Budgets, retries, scheduling
# ════════════════════════════════════════════════════════════════════

# Daily soft cap on tokens spent across ALL projects.
AIDEVSWARM_DAILY_TOKEN_BUDGET=2000000
# Hard cap per milestone (circuit breaker).
AIDEVSWARM_PER_MILESTONE_TOKEN_BUDGET=1000000
# How many projects build concurrently. 1 is the safe default;
# raise carefully — LLM cost scales linearly.
AIDEVSWARM_BUILD_CONCURRENCY=1
# How many times a failed milestone retries before the project
# moves to BLOCKED.
AIDEVSWARM_MILESTONE_RETRY_LIMIT=3
# true (default) → an accepted idea is planned then PARKS at
# awaiting_approval until you approve it (web UI or Telegram); only
# then does it start coding + pushing. false → fully autonomous, no
# human gate. Keep true unless you fully trust the swarm + your budget.
AIDEVSWARM_REQUIRE_APPROVAL=true
# Seconds between orchestrator ticks.
AIDEVSWARM_TICK_SECONDS=30
# Ideation gate: an idea must score >= this (and be novel) to become a
# project; otherwise the crew re-ideates up to MAX_ROUNDS times.
AIDEVSWARM_IDEATION_MIN_SCORE=80
AIDEVSWARM_IDEATION_MAX_ROUNDS=5
# Per-call caps the Claude Agent SDK enforces on the Developer/Tester.
# 40 turns is too few to finish a real scaffold milestone; 80 gives
# room. The SDK aborts at the USD cap regardless.
AIDEVSWARM_SDK_MAX_TURNS=80
AIDEVSWARM_SDK_MAX_BUDGET_USD=5.0
# The Tester's turn cap (lower than the build cap — testing is more
# bounded). Trims recurring per-milestone Tester spend.
AIDEVSWARM_TESTER_MAX_TURNS=40
# On a CI gate failure, re-invoke the Developer with the exact lint/type/test
# errors and re-run CI up to this many times BEFORE the milestone counts a
# failed attempt — so a trivial fix (e.g. an unused import) self-heals
# in-attempt instead of burning a whole retry. 0 disables the loop.
AIDEVSWARM_CI_REPAIR_ATTEMPTS=2
# CI sandbox for generated code:
#   docker     — runs tests in an ephemeral, network-less container (most
#                isolated; needs the host Docker socket + the
#                aidevswarm-sandbox image).
#   subprocess — installs each milestone into a throwaway uv venv and
#                runs ruff + mypy --strict + pytest in-process. Real
#                tests, no Docker socket required. The compose stack
#                defaults to this because the orchestrator container has
#                no Docker socket.
#   inmemory   — treats CI as pass WITHOUT running anything (last resort;
#                quality then rests on the Reviewer alone).
AIDEVSWARM_SANDBOX_MODE=docker

# ════════════════════════════════════════════════════════════════════
# Phase 4 replanner + consolidation
# ════════════════════════════════════════════════════════════════════

# Auto-split heuristic: if predicted turns/cost on the next milestone
# exceeds these, the orchestrator bisects it BEFORE calling the LLM
# replanner.
AIDEVSWARM_AUTO_SPLIT_MAX_TURNS=30
AIDEVSWARM_AUTO_SPLIT_MAX_COST_USD=3.0
# Every Nth successful milestone, the orchestrator inserts a
# "consolidation" milestone (tidy + verify, no new features).
AIDEVSWARM_CONSOLIDATION_EVERY=5

# ════════════════════════════════════════════════════════════════════
# Workspace + observability
# ════════════════════════════════════════════════════════════════════

# Where the orchestrator keeps persistent per-project git workspaces.
# Inside docker compose this is bind-mounted from ./workspaces on the
# host so workspaces survive container restarts.
AIDEVSWARM_WORKSPACES_DIR=/workspace/workspaces

# Phoenix observability bootstrap. Leave `true` so every CrewAI agent
# step appears in the Phoenix UI at http://localhost:6006.
AIDEVSWARM_PHOENIX_ENABLED=true
AIDEVSWARM_PHOENIX_ENDPOINT=http://phoenix:6006/v1/traces

# ════════════════════════════════════════════════════════════════════
# Phase 5 redaction — last line of defense against secret leakage
# ════════════════════════════════════════════════════════════════════

# Comma-separated regex list. Default catches sk-ant-*, ghp_*, xoxb-*,
# JWTs, Telegram bot tokens. Add your own patterns if you store other
# secret-shaped strings.
# AIDEVSWARM_REDACT_PATTERNS=
